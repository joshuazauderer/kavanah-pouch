NODE_ENV=production
PORT=3000
APP_BASE_URL=https://kavanahpouch.com

# PostgreSQL (set by Coolify or manually)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Session
SESSION_SECRET=replace_with_long_random_string_at_least_64_chars

# Admin first-run bootstrap (used by npm run seed-admin, then remove from env)
ADMIN_EMAIL=admin@kavanahpouch.com
ADMIN_INITIAL_PASSWORD=replace_for_first_login_only

# Stripe (use test keys first; switch to live only after full end-to-end test)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_TWO_PACK=price_xxx
STRIPE_PRICE_THREE_PACK=price_xxx

# Package defaults (update after weighing/measuring sample)
DEFAULT_PACKAGE_WEIGHT_OZ=8
DEFAULT_PACKAGE_LENGTH_IN=13
DEFAULT_PACKAGE_WIDTH_IN=10
DEFAULT_PACKAGE_HEIGHT_IN=1

# Owner notification email (optional — skip SMTP vars to disable email)
OWNER_NOTIFICATION_EMAIL=owner@kavanahpouch.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kavanahpouch.com
