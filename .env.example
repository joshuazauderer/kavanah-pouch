NODE_ENV=production
PORT=3000
APP_BASE_URL=https://kavanahpouch.com

# PostgreSQL (set by Coolify or manually)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Session
SESSION_SECRET=replace_with_long_random_string_at_least_64_chars

# Admin first-run bootstrap (used by npm run seed-admin, then remove from env)
ADMIN_EMAIL=admin@kavanahpouch.com
ADMIN_INITIAL_PASSWORD=replace_for_first_login_only

# Stripe (use test keys first; switch to live only after full end-to-end test)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe product Price IDs (create one per SKU in the Stripe dashboard)
STRIPE_PRICE_1_POUCH=price_xxx
STRIPE_PRICE_2_PACK=price_xxx
STRIPE_PRICE_3_PACK=price_xxx

# Stripe Shipping Rate IDs (create in Stripe dashboard under Products > Shipping rates)
# FLAT_US: $4.95  FREE_US: $0.00
STRIPE_SHIPPING_RATE_FLAT_US=shr_xxx
STRIPE_SHIPPING_RATE_FREE_US=shr_xxx

# Package defaults (update after weighing/measuring sample)
DEFAULT_PACKAGE_WEIGHT_OZ=8
DEFAULT_PACKAGE_LENGTH_IN=13
DEFAULT_PACKAGE_WIDTH_IN=10
DEFAULT_PACKAGE_HEIGHT_IN=1

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY is required for all outbound email (customer confirmations + owner alerts).
# FROM_EMAIL must be from a domain verified in your Resend account.
# The default sending domain is artcertify.store (already verified).
# To send from orders@kavanahpouch.com, verify kavanahpouch.com in Resend first.
RESEND_API_KEY=re_xxx
FROM_EMAIL=orders@kavanahpouch.com
FROM_NAME=Kavanah Pouch
SUPPORT_EMAIL=support@kavanahpouch.com
OWNER_NOTIFICATION_EMAIL=owner@kavanahpouch.com
